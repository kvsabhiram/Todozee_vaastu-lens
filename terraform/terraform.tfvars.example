# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.

aws_region   = "ap-south-1"
project_name = "vaastu-lens"
environment  = "prod"

# Compute — t3.large (8 GB) comfortably fits torch + yolov8m on CPU.
instance_type    = "t3.large"
root_volume_size = 30

# Access
app_port           = 5004
allowed_http_cidrs = ["0.0.0.0/0"]

# Public hostname served via Caddy auto-HTTPS. Leave "" to serve plain HTTP.
# Add a DNS A record: <domain> -> the instance Elastic IP (see `dns_record_needed`).
domain = ""
# Lock SSH to your IP, or leave empty to disable SSH entirely (SSM still works).
allowed_ssh_cidrs = []
# Optional existing EC2 key pair for break-glass SSH.
key_pair_name = ""

# CI/CD
github_repository = "kvsabhiram/Todozee_vaastu-lens"
github_branch     = "main"
# Set to false if token.actions.githubusercontent.com already exists in the account.
create_oidc_provider = true

# Alerting — where CloudWatch alarm notifications go (confirm the SNS email once).
# Leave empty to create the topic/alarms without an email subscription.
alarm_email           = ""
error_alarm_threshold = 1
